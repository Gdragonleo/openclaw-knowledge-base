/* app.wxss — 全局样式 */

/* ===== 基础重置 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  background-color: #FAF9DE;
  box-sizing: border-box;
}

view, text, input, button, scroll-view {
  box-sizing: border-box;
}

/* ===== 全局颜色变量（兼容写法） ===== */
/* 主色：麻将绿 #2E8B57 */
/* 背景：宣纸黄 #FAF9DE */
/* 强调：流光金 #D4AF37 */
/* 警示：朱砂红 #B22222 */
/* 文字：深灰  #333333 */

/* ===== 通用卡片样式 ===== */
.card {
  background: #FFFEF0;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(46, 139, 87, 0.1);
  border: 1rpx solid #E8D9A9;
  margin-bottom: 24rpx;
}

/* ===== 通用标题 ===== */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2E8B57;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #D4AF37;
}

/* ===== 通用按钮 ===== */
.btn-primary {
  background: linear-gradient(135deg, #2E8B57, #1E6B47);
  color: #FFFEF0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border: 2rpx solid #D4AF37;
}

.btn-secondary {
  background: #FFFEF0;
  color: #2E8B57;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: 2rpx solid #2E8B57;
}

/* ===== 安全区适配 ===== */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
