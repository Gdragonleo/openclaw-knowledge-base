/* 麻将算命 - 结果展示页样式 */
/* 国风配色方案：万=#C62828，筒=#2E7D32，条=#1565C0，背景=#FAF9F6 */

.result-container {
  min-height: 100vh;
  background-color: #FAF9F6; /* 宣纸纹理背景色 */
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
}

/* 头部区域 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1rpx solid #E0E0E0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.back-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #2C3E50;
  padding: 12rpx 0;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.share-btn {
  padding: 12rpx;
}

.share-icon {
  font-size: 32rpx;
  color: #7F8C8D;
}

/* 主内容区 */
.main-content {
  height: calc(100vh - 200rpx);
  padding: 32rpx;
}

/* 命盘圆形图 */
.fortune-wheel-container {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.wheel-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 24rpx;
  text-align: center;
}

/* 今日吉方方位 */
.lucky-direction-container {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.direction-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 20rpx;
  text-align: center;
}

.direction-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.3);
}

.direction-main {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.direction-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.direction-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.direction-desc {
  font-size: 24rpx;
  color: #FFFFFF;
  text-align: center;
}

.direction-grid {
  display: flex;
  justify-content: space-between;
  padding: 0 10rpx;
}

.direction-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background-color: #F5F5F5;
  min-width: 70rpx;
  border: 2rpx solid #E0E0E0;
}

.direction-item.lucky {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 165, 0, 0.4);
  border-color: #FFA500;
}

.dir-name {
  font-size: 22rpx;
  color: #2C3E50;
  margin-bottom: 4rpx;
}

.direction-item.lucky .dir-name {
  color: #FFFFFF;
  font-weight: 600;
}

.dir-icon {
  font-size: 24rpx;
}

.wheel-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.wheel-base {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: conic-gradient(
    #C62828 0deg 120deg,
    #2E7D32 120deg 240deg,
    #1565C0 240deg 360deg
  );
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15),
              0 0 0 6rpx rgba(255, 255, 255, 0.8),
              inset 0 0 20rpx rgba(0, 0, 0, 0.1);
}

.color-segment {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  clip-path: polygon(50% 50%, 50% 0%, 100% 0%, 100% 100%, 50% 50%);
  transform-origin: 50% 50%;
}

.segment-label {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.mahjong-icons {
  position: absolute;
  width: 100%;
  height: 100%;
}

.icon-wan, .icon-tong, .icon-tiao {
  position: absolute;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.icon-wan {
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
}

.icon-tong {
  top: 160rpx;
  right: 60rpx;
}

.icon-tiao {
  top: 160rpx;
  left: 60rpx;
}

.fortune-indicator {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 120rpx;
  height: 2rpx;
  background-color: #F57C00;
  transform-origin: 0 50%;
  z-index: 10;
}

.indicator-line {
  width: 100%;
  height: 100%;
  background-color: #F57C00;
}

.indicator-head {
  position: absolute;
  right: -8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  background-color: #F57C00;
  border-radius: 50%;
}

.wheel-center {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80rpx;
  height: 80rpx;
  background-color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

/* 增强的中心显示效果 */
.wheel-center.enhanced {
  width: 140rpx;
  height: 140rpx;
  flex-direction: column;
  border: 4rpx solid #F57C00;
  box-shadow: 0 6rpx 20rpx rgba(245, 124, 0, 0.4), inset 0 0 20rpx rgba(245, 124, 0, 0.1);
}

.center-suit {
  font-size: 44rpx;
  font-weight: bold;
  color: #2C3E50;
  line-height: 1;
}

.center-score {
  font-size: 22rpx;
  color: #F57C00;
  font-weight: 600;
  margin-top: 4rpx;
}

/* 花色得分展示 */
.suit-scores {
  display: flex;
  justify-content: space-around;
  margin-top: 24rpx;
}

.suit-score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s ease;
}

.suit-score-item.active {
  border-color: #F57C00;
  background-color: #FFF3E0;
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(245, 124, 0, 0.2);
}

.suit-color {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.color-wan {
  background-color: #C62828;
}

.color-tong {
  background-color: #2E7D32;
}

.color-tiao {
  background-color: #1565C0;
}

.suit-name {
  font-size: 24rpx;
  color: #2C3E50;
  margin-bottom: 4rpx;
}

.suit-score {
  font-size: 20rpx;
  color: #7F8C8D;
}

/* 牌型信息卡片 */
.hand-type-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.hand-type-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #F57C00;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.hand-type-icon .icon {
  font-size: 40rpx;
  color: #FFFFFF;
}

.hand-type-info {
  flex: 1;
}

.hand-type-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.hand-type-score {
  font-size: 24rpx;
  color: #F57C00;
}

.card-body {
  margin-bottom: 24rpx;
}

.hand-type-description {
  font-size: 26rpx;
  line-height: 1.6;
  color: #2C3E50;
  margin-bottom: 24rpx;
}

.hand-type-stats {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-label {
  width: 120rpx;
  font-size: 24rpx;
  color: #7F8C8D;
}

.stat-bar {
  flex: 1;
  height: 16rpx;
  background-color: #EEEEEE;
  border-radius: 8rpx;
  margin: 0 16rpx;
  overflow: hidden;
}

.stat-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.stat-value {
  width: 80rpx;
  font-size: 24rpx;
  color: #2C3E50;
  text-align: right;
}

.difficulty-stars {
  flex: 1;
  margin: 0 16rpx;
}

.star {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.star.active {
  color: #F57C00;
}

.star.inactive {
  color: #E0E0E0;
}

.card-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #EEEEEE;
}

.tips-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #F57C00;
  margin-right: 8rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #7F8C8D;
  line-height: 1.4;
}

/* 备选牌型 */
.alternative-patterns {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 20rpx;
}

.patterns-scroll {
  white-space: nowrap;
}

.patterns-list {
  display: inline-flex;
  gap: 20rpx;
}

.pattern-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #F5F5F5;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  min-width: 160rpx;
}

.pattern-name {
  font-size: 24rpx;
  color: #2C3E50;
  margin-bottom: 8rpx;
  text-align: center;
}

.pattern-score {
  font-size: 20rpx;
  color: #7F8C8D;
}

/* 吃什么喝什么转运建议 */
.food-recommendation {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.food-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 16rpx;
  padding: 24rpx;
}

.food-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
}

.food-element {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
}

.food-tip {
  font-size: 20rpx;
  color: #7F8C8D;
}

.food-content {
  margin-bottom: 20rpx;
}

.food-main {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.food-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.food-details {
  flex: 1;
}

.food-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.food-desc {
  font-size: 22rpx;
  color: #5D6D7E;
  line-height: 1.4;
}

.food-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.food-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.item-name {
  font-size: 22rpx;
  color: #2C3E50;
}

.food-advice {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 12rpx;
}

.advice-icon {
  font-size: 24rpx;
  margin-right: 12rpx;
}

.advice-text {
  font-size: 22rpx;
  color: #5D6D7E;
  line-height: 1.5;
  flex: 1;
}

/* 运势描述区 */
.fortune-description {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.time-range {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.time-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #7F8C8D;
}

.time-text {
  font-size: 24rpx;
  color: #2C3E50;
}

.overall-fortune {
  margin-bottom: 24rpx;
}

.fortune-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.fortune-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #2C3E50;
}

.detailed-analysis {
  margin-bottom: 24rpx;
}

.analysis-item {
  margin-bottom: 20rpx;
}

.analysis-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.suit-color-small {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
}

.analysis-suit {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C3E50;
}

.analysis-text {
  font-size: 22rpx;
  line-height: 1.5;
  color: #7F8C8D;
  padding-left: 32rpx;
}

.recommendations {
  padding-top: 20rpx;
  border-top: 1rpx solid #EEEEEE;
}

.rec-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.rec-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rec-item {
  display: flex;
  align-items: flex-start;
}

.rec-icon {
  font-size: 20rpx;
  color: #4CAF50;
  margin-right: 12rpx;
  margin-top: 4rpx;
}

.rec-text {
  font-size: 22rpx;
  line-height: 1.5;
  color: #2C3E50;
  flex: 1;
}

/* 底部操作区 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #E0E0E0;
  display: flex;
  gap: 16rpx;
  z-index: 100;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background-color: #F5F5F5;
  color: #2C3E50;
}

.action-btn .btn-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.share-btn {
  background-color: #E3F2FD;
  color: #1565C0;
}

.save-btn {
  background-color: #FFF3E0;
  color: #F57C00;
}

.retry-btn {
  background-color: #E8F5E9;
  color: #2E7D32;
}

/* 测算时间显示 */
.calculation-time {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 12rpx;
  border-left: 4rpx solid #9B59B6;
}

.calc-time-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.calc-time-text {
  font-size: 24rpx;
  color: #5D6D7E;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .main-content {
    padding: 24rpx;
  }

  .fortune-wheel-container,
  .hand-type-card,
  .alternative-patterns,
  .fortune-description {
    padding: 24rpx;
  }

  .wheel-base {
    width: 240rpx;
    height: 240rpx;
  }
}